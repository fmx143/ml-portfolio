# --- Virtual environment (never commit — it's huge & machine-specific) ---
.venv/
venv/
env/

# --- Python bytecode / caches ---
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Jupyter ---
.ipynb_checkpoints/
*/.ipynb_checkpoints/
profile_default/
ipython_config.py

# --- Distribution / packaging ---
build/
dist/
*.egg-info/
.eggs/

# --- Environment / secrets (safety) ---
.env
.env.*
*.key
*.pem
secrets.*

# --- OS / editor cruft ---
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*~

# NOTE: data/*.csv is intentionally NOT ignored — projects #2 and #3 cache
# market-price CSVs there so the notebooks re-run offline (see CLAUDE.md).
